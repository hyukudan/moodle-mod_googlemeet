{{!
  @template mod_googlemeet/recording_hub
}}
<div id="googlemeet-recording-hub" class="googlemeet-recording-hub" data-cmid="{{cmid}}" data-recordingid="{{recordingid}}">
  <div class="mb-3">
    <a href="{{backurl}}" class="btn btn-link px-0">&lsaquo; {{# str }} hub_back_to_recordings, mod_googlemeet {{/ str }}</a>
  </div>

  <div class="ratio ratio-16x9 mb-3 googlemeet-recording-player">
    <iframe src="{{embedurl}}" allow="autoplay; encrypted-media" allowfullscreen title="{{name}}"></iframe>
  </div>

  <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
      <h3 class="mb-1">
        <span class="recording-name-text">{{name}}</span>
        {{#caneditrecording}}
          <a href="javascript:void(0);" role="button" class="recordingeditname googlemeet-edit-btn ms-1" data-id="{{recordingid}}" title="{{# str }} edit {{/ str }}" aria-label="{{# str }} edit {{/ str }}">
            {{# pix }} i/edit, core {{/ pix }}
          </a>
        {{/caneditrecording}}
      </h3>
      <div class="text-muted">{{duration}}</div>
    </div>
    <div class="d-flex align-items-center gap-2">
      <a href="{{webviewlink}}" class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener">
        {{# pix }} i/externallink, core {{/ pix }} {{# str }} openindrive, mod_googlemeet {{/ str }}
      </a>
      {{#caneditrecording}}
        <a href="javascript:void(0);" class="btn btn-outline-secondary btn-sm recordinghowhide" data-id="{{recordingid}}">
          {{# str }} showhide, mod_googlemeet {{/ str }}
        </a>
      {{/caneditrecording}}
    </div>
  </div>

  <ul class="nav nav-tabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link {{#summaryactive}}active{{/summaryactive}}" id="googlemeet-summary-tab" data-bs-toggle="tab" data-bs-target="#googlemeet-summary-panel" type="button" role="tab" aria-controls="googlemeet-summary-panel" aria-selected="{{#summaryactive}}true{{/summaryactive}}{{^summaryactive}}false{{/summaryactive}}">
        {{# str }} hub_tab_summary, mod_googlemeet {{/ str }}
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link {{#questionsactive}}active{{/questionsactive}}" id="googlemeet-questions-tab" data-bs-toggle="tab" data-bs-target="#googlemeet-questions-panel" type="button" role="tab" aria-controls="googlemeet-questions-panel" aria-selected="{{#questionsactive}}true{{/questionsactive}}{{^questionsactive}}false{{/questionsactive}}">
        {{# str }} hub_tab_questions, mod_googlemeet {{/ str }}
        {{#canmanagequestions}}
          {{#hasdrafts}}({{draftcount}} {{# str }} question_status_draft, mod_googlemeet {{/ str }}){{/hasdrafts}}
          {{^hasdrafts}}{{#publishedcount}}({{publishedcount}}){{/publishedcount}}{{/hasdrafts}}
        {{/canmanagequestions}}
      </button>
    </li>
    {{#showmaterials}}
    <li class="nav-item" role="presentation">
      <button class="nav-link {{#materialsactive}}active{{/materialsactive}}" id="googlemeet-materials-tab" data-bs-toggle="tab" data-bs-target="#googlemeet-materials-panel" type="button" role="tab" aria-controls="googlemeet-materials-panel" aria-selected="{{#materialsactive}}true{{/materialsactive}}{{^materialsactive}}false{{/materialsactive}}">
        {{# str }} hub_tab_materials, mod_googlemeet {{/ str }}
        {{#materialcount}}<span class="badge bg-secondary ms-1">{{materialcount}}</span>{{/materialcount}}
      </button>
    </li>
    {{/showmaterials}}
    {{#caneditrecording}}
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="googlemeet-transcript-tab" data-bs-toggle="tab" data-bs-target="#googlemeet-transcript-panel" type="button" role="tab" aria-controls="googlemeet-transcript-panel" aria-selected="false">
        {{# str }} hub_tab_transcript, mod_googlemeet {{/ str }}
      </button>
    </li>
    {{/caneditrecording}}
    {{#hasnotes}}
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="googlemeet-notes-tab" data-bs-toggle="tab" data-bs-target="#googlemeet-notes-panel" type="button" role="tab" aria-controls="googlemeet-notes-panel" aria-selected="false">
        {{# str }} hub_tab_notes, mod_googlemeet {{/ str }}
      </button>
    </li>
    {{/hasnotes}}
  </ul>

  <div class="tab-content pt-3">
    <div class="tab-pane fade {{#summaryactive}}show active{{/summaryactive}}" id="googlemeet-summary-panel" role="tabpanel" aria-labelledby="googlemeet-summary-tab">
      {{#hasanalysis}}
        <div class="googlemeet-ai-section googlemeet-ai-summary">
          <h5>{{# str }} ai_summary, mod_googlemeet {{/ str }}</h5>
          <div>{{{summary}}}</div>
        </div>
        {{#keypoints.0}}
        <div class="googlemeet-ai-section googlemeet-ai-keypoints mt-3">
          <h5>{{# str }} ai_keypoints, mod_googlemeet {{/ str }}</h5>
          <ul>{{#keypoints}}<li>{{text}}</li>{{/keypoints}}</ul>
        </div>
        {{/keypoints.0}}
        {{#topics.0}}
        <div class="googlemeet-ai-section googlemeet-ai-topics mt-3">
          <h5>{{# str }} ai_topics, mod_googlemeet {{/ str }}</h5>
          <div class="googlemeet-ai-topics-tags">{{#topics}}<span class="googlemeet-ai-topic-badge">{{text}}</span>{{/topics}}</div>
        </div>
        {{/topics.0}}
      {{/hasanalysis}}
      {{^hasanalysis}}
        {{#aistatusisprocessing}}<div class="alert alert-info">{{# str }} ai_status_chip_processing, mod_googlemeet {{/ str }}</div>{{/aistatusisprocessing}}
        {{#aistatusispending}}<div class="alert alert-info">{{# str }} ai_status_chip_pending, mod_googlemeet {{/ str }}</div>{{/aistatusispending}}
        {{#aistatusisfailed}}<div class="alert alert-warning">{{# str }} ai_status_chip_failed_student, mod_googlemeet {{/ str }}{{#aierror}}<div class="small text-muted mt-1">{{aierror}}</div>{{/aierror}}</div>{{/aistatusisfailed}}
        {{^aistatusisprocessing}}{{^aistatusispending}}{{^aistatusisfailed}}
          {{#aienabled}}<div class="alert alert-info">{{# str }} ai_noanalysis, mod_googlemeet {{/ str }}</div>{{/aienabled}}
          {{^aienabled}}<div class="alert alert-secondary">{{# str }} ai_notconfigured, mod_googlemeet {{/ str }}</div>{{/aienabled}}
        {{/aistatusisfailed}}{{/aistatusispending}}{{/aistatusisprocessing}}
      {{/hasanalysis}}
    </div>

    <div class="tab-pane fade {{#questionsactive}}show active{{/questionsactive}}" id="googlemeet-questions-panel" role="tabpanel" aria-labelledby="googlemeet-questions-tab">
      {{#canmanagequestions}}
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
          <div>
            <strong>{{questioncount}}</strong> {{# str }} hub_tab_questions, mod_googlemeet {{/ str }}
            {{#draftcount}}<span class="badge bg-warning text-dark ms-1">{{draftcount}} {{# str }} question_status_draft, mod_googlemeet {{/ str }}</span>{{/draftcount}}
            {{#publishedcount}}<span class="badge bg-success ms-1">{{publishedcount}} {{# str }} question_status_published, mod_googlemeet {{/ str }}</span>{{/publishedcount}}
          </div>
          {{#aienabled}}
          <button type="button" class="btn btn-primary btn-sm googlemeet-question-generate" data-count="10" {{#generationqueued}}disabled{{/generationqueued}}>
            {{#generationqueued}}{{# str }} question_generating, mod_googlemeet {{/ str }}{{/generationqueued}}
            {{^generationqueued}}
              {{#hasquestions}}{{# str }} question_generate_more, mod_googlemeet {{/ str }}{{/hasquestions}}
              {{^hasquestions}}{{# str }} question_generate_ai, mod_googlemeet {{/ str }}{{/hasquestions}}
            {{/generationqueued}}
          </button>
          {{/aienabled}}
        </div>
        {{#generationqueued}}
          <div class="alert alert-info googlemeet-question-generating">{{# str }} question_generating, mod_googlemeet {{/ str }}</div>
        {{/generationqueued}}
        {{^hasquestions}}
          <div class="alert alert-secondary">{{# str }} question_empty_teacher, mod_googlemeet {{/ str }}</div>
        {{/hasquestions}}
        {{#hasquestions}}
          <div class="mb-3 d-flex gap-2 flex-wrap">
            <button type="button" class="btn btn-outline-success btn-sm googlemeet-question-bulk-publish" disabled>{{# str }} question_bulk_publish, mod_googlemeet {{/ str }}</button>
            <button type="button" class="btn btn-outline-danger btn-sm googlemeet-question-bulk-discard" disabled>{{# str }} question_bulk_discard, mod_googlemeet {{/ str }}</button>
          </div>
          <div class="googlemeet-question-list">
            {{#questions}}
              <div class="card mb-3 googlemeet-question-card" data-questionid="{{id}}">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <div class="d-flex align-items-start gap-2" style="min-width:0;">
                      <input class="form-check-input mt-1 flex-shrink-0 googlemeet-question-select" type="checkbox" value="{{id}}" id="googlemeet-question-select-{{id}}" aria-label="{{# str }} select {{/ str }}">
                      <label class="fw-bold mb-0 text-break" for="googlemeet-question-select-{{id}}">{{{stem}}}</label>
                    </div>
                    <span class="badge flex-shrink-0 {{#isready}}bg-success{{/isready}}{{#isdraft}}bg-warning text-dark{{/isdraft}}">{{statuslabel}}</span>
                  </div>
                  <ol class="mt-2">
                    {{#answers}}
                      <li class="{{#correct}}fw-bold text-success{{/correct}}">{{{text}}}</li>
                    {{/answers}}
                  </ol>
                  <div class="border-top pt-2 small">{{{generalfeedback}}}</div>
                  <div class="d-flex gap-2 flex-wrap mt-3">
                    {{#isdraft}}<button type="button" class="btn btn-success btn-sm googlemeet-question-publish">{{# str }} question_publish, mod_googlemeet {{/ str }}</button>{{/isdraft}}
                    {{#isready}}<button type="button" class="btn btn-outline-warning btn-sm googlemeet-question-unpublish">{{# str }} question_unpublish, mod_googlemeet {{/ str }}</button>{{/isready}}
                    {{#isdraft}}<button type="button" class="btn btn-outline-danger btn-sm googlemeet-question-discard">{{# str }} question_discard, mod_googlemeet {{/ str }}</button>{{/isdraft}}
                    <button type="button" class="btn btn-outline-secondary btn-sm googlemeet-question-edit"
                      data-stem="{{stemplain}}"
                      data-feedback="{{generalfeedbackplain}}"
                      data-correctindex="{{correctindex}}"
                      {{#answers}}
                        data-answer{{index}}="{{plain}}"
                      {{/answers}}>
                      {{# str }} question_edit, mod_googlemeet {{/ str }}
                    </button>
                    <a href="{{advancedurl}}" class="btn btn-link btn-sm">{{# str }} question_advanced_edit, mod_googlemeet {{/ str }}</a>
                  </div>
                </div>
              </div>
            {{/questions}}
          </div>
        {{/hasquestions}}
      {{/canmanagequestions}}
      {{^canmanagequestions}}
        {{#hasquestions}}
          <div class="googlemeet-practice-player" data-loaded="0" data-progress-tpl="{{# str }} practice_progress, mod_googlemeet {{/ str }}">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
              <h5 class="mb-0">{{# str }} practice_title, mod_googlemeet {{/ str }}</h5>
              <span class="badge bg-secondary googlemeet-practice-progress" aria-live="polite"></span>
            </div>
            <div class="googlemeet-practice-loading alert alert-info">{{# str }} practice_loading, mod_googlemeet {{/ str }}</div>
            <div class="googlemeet-practice-error alert alert-danger d-none" role="alert"></div>
            <div class="googlemeet-practice-question d-none">
              <fieldset class="border rounded p-3 mb-3">
                <legend class="googlemeet-practice-stem h6 mb-3"></legend>
                <div class="googlemeet-practice-options"></div>
              </fieldset>
              <div class="googlemeet-practice-feedback d-none mb-3" aria-live="polite"></div>
              <div class="d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-primary googlemeet-practice-check" disabled>{{# str }} practice_check, mod_googlemeet {{/ str }}</button>
                <button type="button" class="btn btn-secondary googlemeet-practice-next d-none">{{# str }} practice_next, mod_googlemeet {{/ str }}</button>
              </div>
            </div>
            <div class="googlemeet-practice-complete alert alert-success d-none">
              <div class="fw-bold mb-2">{{# str }} practice_finished, mod_googlemeet {{/ str }}</div>
              <button type="button" class="btn btn-outline-primary btn-sm googlemeet-practice-retry">{{# str }} practice_retry, mod_googlemeet {{/ str }}</button>
            </div>
          </div>
        {{/hasquestions}}
        {{^hasquestions}}
          <div class="alert alert-secondary">{{# str }} question_empty_student, mod_googlemeet {{/ str }}</div>
        {{/hasquestions}}
      {{/canmanagequestions}}
    </div>

    {{#showmaterials}}
    <div class="tab-pane fade {{#materialsactive}}show active{{/materialsactive}}" id="googlemeet-materials-panel" role="tabpanel" aria-labelledby="googlemeet-materials-tab">
      {{#caneditrecording}}{{#hasmaterials}}
        <div class="d-flex justify-content-end mb-3">
          <a href="{{managematerialsurl}}" class="btn btn-primary btn-sm">{{# str }} materials_manage, mod_googlemeet {{/ str }}</a>
        </div>
      {{/hasmaterials}}{{/caneditrecording}}
      {{#hasmaterials}}
        <ul class="list-group">
          {{#materials}}
            <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
              <div class="me-auto" style="min-width:0;">
                <div class="text-break">{{name}}</div>
                <div class="small text-muted">{{size}} &middot; {{modified}}{{#filepath}} &middot; {{filepath}}{{/filepath}}</div>
              </div>
              <a href="{{url}}" class="btn btn-outline-secondary btn-sm flex-shrink-0" aria-label="{{# str }} download {{/ str }}: {{name}}">{{# str }} download {{/ str }}</a>
            </li>
          {{/materials}}
        </ul>
      {{/hasmaterials}}
      {{^hasmaterials}}
        {{#caneditrecording}}
          <div class="alert alert-secondary">{{# str }} materials_empty_teacher, mod_googlemeet {{/ str }}</div>
          <a href="{{managematerialsurl}}" class="btn btn-primary btn-sm">{{# str }} materials_manage, mod_googlemeet {{/ str }}</a>
        {{/caneditrecording}}
        {{^caneditrecording}}
          <div class="alert alert-secondary">{{# str }} materials_none, mod_googlemeet {{/ str }}</div>
        {{/caneditrecording}}
      {{/hasmaterials}}
    </div>
    {{/showmaterials}}

    {{#caneditrecording}}
    <div class="tab-pane fade" id="googlemeet-transcript-panel" role="tabpanel" aria-labelledby="googlemeet-transcript-tab">
      {{#hasanalysis}}<div class="googlemeet-ai-transcript-text">{{{transcript}}}</div>{{/hasanalysis}}
      {{^hasanalysis}}<div class="alert alert-info">{{# str }} ai_transcript_loading, mod_googlemeet {{/ str }}</div>{{/hasanalysis}}
    </div>
    {{/caneditrecording}}
    {{#hasnotes}}
    <div class="tab-pane fade" id="googlemeet-notes-panel" role="tabpanel" aria-labelledby="googlemeet-notes-tab">
      <div class="googlemeet-ai-notes-text">{{{notes}}}</div>
    </div>
    {{/hasnotes}}
  </div>

  <div class="modal fade" id="googlemeet-question-edit-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">{{# str }} question_edit, mod_googlemeet {{/ str }}</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{# str }} closebuttontitle {{/ str }}"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="googlemeet-question-edit-id">
          <div class="mb-2">
            <label class="form-label" for="googlemeet-question-edit-stem">{{# str }} question_stem, mod_googlemeet {{/ str }}</label>
            <textarea class="form-control" id="googlemeet-question-edit-stem" rows="3"></textarea>
          </div>
          <div class="row">
            <div class="col-md-6 mb-2"><div class="input-group"><span class="input-group-text">A</span><input class="form-control googlemeet-question-edit-answer" data-index="0" aria-label="A"></div></div>
            <div class="col-md-6 mb-2"><div class="input-group"><span class="input-group-text">B</span><input class="form-control googlemeet-question-edit-answer" data-index="1" aria-label="B"></div></div>
            <div class="col-md-6 mb-2"><div class="input-group"><span class="input-group-text">C</span><input class="form-control googlemeet-question-edit-answer" data-index="2" aria-label="C"></div></div>
            <div class="col-md-6 mb-2"><div class="input-group"><span class="input-group-text">D</span><input class="form-control googlemeet-question-edit-answer" data-index="3" aria-label="D"></div></div>
          </div>
          <div class="mb-2">
            <label class="form-label" for="googlemeet-question-edit-correct">{{# str }} question_correct_answer, mod_googlemeet {{/ str }}</label>
            <select class="form-select" id="googlemeet-question-edit-correct">
              <option value="0">A</option><option value="1">B</option><option value="2">C</option><option value="3">D</option>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label" for="googlemeet-question-edit-feedback">{{# str }} question_explanation, mod_googlemeet {{/ str }}</label>
            <textarea class="form-control" id="googlemeet-question-edit-feedback" rows="4"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{# str }} cancel {{/ str }}</button>
          <button type="button" class="btn btn-primary" id="googlemeet-question-edit-save">{{# str }} savechanges {{/ str }}</button>
        </div>
      </div>
    </div>
  </div>
</div>

{{#js}}
require(['jquery', 'core/ajax', 'core/notification'], function($, Ajax, Notification) {
  var cmid = {{cmid}};
  var recordingid = {{recordingid}};

  function selectedIds() {
    return $('.googlemeet-question-select:checked').map(function() {
      return parseInt(this.value, 10);
    }).get();
  }

  function call(methodname, args) {
    return Ajax.call([{methodname: methodname, args: args}])[0]
      .then(function() { window.location.reload(); })
      .fail(Notification.exception);
  }

  $('.googlemeet-question-generate').on('click', function() {
    $(this).prop('disabled', true).text('{{# str }} question_generating, mod_googlemeet {{/ str }}');
    call('mod_googlemeet_queue_generate_questions', {
      recordingid: recordingid,
      coursemoduleid: cmid,
      count: parseInt($(this).attr('data-count'), 10) || 10,
      sesskey: '{{sesskey}}'
    });
  });

  $('.googlemeet-question-publish').on('click', function() {
    call('mod_googlemeet_publish_questions', {
      recordingid: recordingid,
      coursemoduleid: cmid,
      questionids: [parseInt($(this).closest('.googlemeet-question-card').attr('data-questionid'), 10)],
      sesskey: '{{sesskey}}'
    });
  });

  $('.googlemeet-question-unpublish').on('click', function() {
    call('mod_googlemeet_unpublish_questions', {
      recordingid: recordingid,
      coursemoduleid: cmid,
      questionids: [parseInt($(this).closest('.googlemeet-question-card').attr('data-questionid'), 10)],
      sesskey: '{{sesskey}}'
    });
  });

  $('.googlemeet-question-discard').on('click', function() {
    call('mod_googlemeet_discard_questions', {
      recordingid: recordingid,
      coursemoduleid: cmid,
      questionids: [parseInt($(this).closest('.googlemeet-question-card').attr('data-questionid'), 10)],
      sesskey: '{{sesskey}}'
    });
  });

  function refreshBulkState() {
    var hasselection = selectedIds().length > 0;
    $('.googlemeet-question-bulk-publish, .googlemeet-question-bulk-discard').prop('disabled', !hasselection);
  }
  $('.googlemeet-question-select').on('change', refreshBulkState);
  refreshBulkState();

  $('.googlemeet-question-bulk-publish').on('click', function() {
    var ids = selectedIds();
    if (!ids.length) { return; }
    call('mod_googlemeet_publish_questions', {recordingid: recordingid, coursemoduleid: cmid, questionids: ids, sesskey: '{{sesskey}}'});
  });

  $('.googlemeet-question-bulk-discard').on('click', function() {
    var ids = selectedIds();
    if (!ids.length) { return; }
    call('mod_googlemeet_discard_questions', {recordingid: recordingid, coursemoduleid: cmid, questionids: ids, sesskey: '{{sesskey}}'});
  });

  $('.googlemeet-question-edit').on('click', function() {
    var btn = $(this);
    $('#googlemeet-question-edit-id').val(btn.closest('.googlemeet-question-card').attr('data-questionid'));
    $('#googlemeet-question-edit-stem').val(btn.attr('data-stem') || '');
    $('#googlemeet-question-edit-feedback').val(btn.attr('data-feedback') || '');
    $('#googlemeet-question-edit-correct').val(btn.attr('data-correctindex') || '0');
    $('.googlemeet-question-edit-answer').each(function() {
      $(this).val(btn.attr('data-answer' + $(this).attr('data-index')) || '');
    });
    $('#googlemeet-question-edit-modal').modal('show');
  });

  $('#googlemeet-question-edit-save').on('click', function() {
    var options = $('.googlemeet-question-edit-answer').map(function() { return $(this).val(); }).get();
    call('mod_googlemeet_update_question', {
      recordingid: recordingid,
      coursemoduleid: cmid,
      questionid: parseInt($('#googlemeet-question-edit-id').val(), 10),
      stem: $('#googlemeet-question-edit-stem').val(),
      options: options,
      correctindex: parseInt($('#googlemeet-question-edit-correct').val(), 10),
      explanation: $('#googlemeet-question-edit-feedback').val(),
      citation: '',
      sesskey: '{{sesskey}}'
    });
  });

  {{#caneditrecording}}
  $('.recordinghowhide').on('click', function() {
    call('mod_googlemeet_showhide_recording', {recordingid: recordingid, coursemoduleid: cmid});
  });
  $('.recordingeditname').on('click', function() {
    var current = $('.recording-name-text').first().text().trim();
    var name = window.prompt('{{# str }} name, mod_googlemeet {{/ str }}', current);
    if (name) {
      call('mod_googlemeet_recording_edit_name', {recordingid: recordingid, name: name, coursemoduleid: cmid});
    }
  });
  {{/caneditrecording}}

  {{^canmanagequestions}}
  {{#hasquestions}}
  var practice = {
    questions: [],
    index: 0,
    checked: false
  };
  var player = $('.googlemeet-practice-player');

  function findCorrectOption(question, answerid) {
    for (var i = 0; i < question.options.length; i++) {
      if (parseInt(question.options[i].answerid, 10) === parseInt(answerid, 10)) {
        return question.options[i];
      }
    }
    return null;
  }

  function renderPracticeQuestion() {
    var question = practice.questions[practice.index];
    practice.checked = false;
    $('.googlemeet-practice-loading, .googlemeet-practice-complete, .googlemeet-practice-error').addClass('d-none');
    $('.googlemeet-practice-question').removeClass('d-none');
    var progresscur = practice.index + 1;
    var progresstotal = practice.questions.length;
    $('.googlemeet-practice-progress')
      .text(progresscur + ' / ' + progresstotal)
      .attr('aria-label', (player.attr('data-progress-tpl') || (progresscur + ' / ' + progresstotal))
        .replace('{$a->current}', progresscur).replace('{$a->total}', progresstotal));
    $('.googlemeet-practice-stem').html(question.stem);
    $('.googlemeet-practice-feedback').addClass('d-none').removeClass('alert alert-success alert-warning').empty();
    $('.googlemeet-practice-check').prop('disabled', true).removeClass('d-none');
    $('.googlemeet-practice-next').addClass('d-none');

    var optionshtml = '';
    $.each(question.options, function(i, option) {
      var inputid = 'googlemeet-practice-' + question.questionid + '-' + option.answerid;
      optionshtml += '<div class="form-check mb-2">' +
        '<input class="form-check-input googlemeet-practice-answer" type="radio" name="googlemeet-practice-answer" id="' + inputid + '" value="' + option.answerid + '">' +
        '<label class="form-check-label" for="' + inputid + '">' + option.text + '</label>' +
        '</div>';
    });
    $('.googlemeet-practice-options').html(optionshtml);
  }

  function showPracticeComplete() {
    $('.googlemeet-practice-question, .googlemeet-practice-loading, .googlemeet-practice-error').addClass('d-none');
    $('.googlemeet-practice-progress').text(practice.questions.length + ' / ' + practice.questions.length);
    $('.googlemeet-practice-complete').removeClass('d-none');
  }

  function loadPracticeQuestions() {
    if (player.attr('data-loaded') === '1') {
      return;
    }
    player.attr('data-loaded', '1');
    Ajax.call([{
      methodname: 'mod_googlemeet_get_practice_questions',
      args: {recordingid: recordingid, coursemoduleid: cmid}
    }])[0].then(function(response) {
      practice.questions = response.questions || [];
      practice.index = 0;
      if (!practice.questions.length) {
        $('.googlemeet-practice-loading').removeClass('alert-info').addClass('alert-secondary')
          .text('{{# str }} question_empty_student, mod_googlemeet {{/ str }}');
        return;
      }
      renderPracticeQuestion();
    }).fail(function(error) {
      $('.googlemeet-practice-loading').addClass('d-none');
      $('.googlemeet-practice-error').removeClass('d-none').text(error.message || '{{# str }} ai_error_unknown, mod_googlemeet {{/ str }}');
    });
  }

  $('#googlemeet-questions-tab').on('shown.bs.tab', loadPracticeQuestions);
  if ($('#googlemeet-questions-panel').hasClass('active')) {
    loadPracticeQuestions();
  }

  player.on('change', '.googlemeet-practice-answer', function() {
    $('.googlemeet-practice-check').prop('disabled', false);
  });

  $('.googlemeet-practice-check').on('click', function() {
    if (practice.checked) {
      return;
    }
    var question = practice.questions[practice.index];
    var answerid = parseInt($('.googlemeet-practice-answer:checked').val(), 10);
    if (!answerid) {
      return;
    }
    $('.googlemeet-practice-error').addClass('d-none');
    $('.googlemeet-practice-check').prop('disabled', true);
    Ajax.call([{
      methodname: 'mod_googlemeet_check_practice_answer',
      args: {recordingid: recordingid, coursemoduleid: cmid, questionid: question.questionid, answerid: answerid}
    }])[0].then(function(response) {
      practice.checked = true;
      $('.googlemeet-practice-answer').prop('disabled', true);
      $('.googlemeet-practice-answer').each(function() {
        var $wrap = $(this).closest('.form-check');
        if (parseInt($(this).val(), 10) === parseInt(response.correctanswerid, 10)) {
          $wrap.addClass('text-success fw-bold');
        } else if ($(this).is(':checked') && !response.correct) {
          $wrap.addClass('text-danger text-decoration-line-through');
        }
      });
      var correctoption = findCorrectOption(question, response.correctanswerid);
      var correcttext = correctoption ? correctoption.text : '';
      var feedbackclass = response.correct ? 'alert-success' : 'alert-warning';
      var statustext = response.correct ? '{{# str }} practice_correct, mod_googlemeet {{/ str }}' : '{{# str }} practice_incorrect, mod_googlemeet {{/ str }}';
      var icon = response.correct ? '&#10003;' : '!';
      $('.googlemeet-practice-feedback')
        .removeClass('d-none alert-success alert-warning')
        .addClass('alert ' + feedbackclass)
        .html('<div class="fw-bold"><span aria-hidden="true">' + icon + '</span> ' + statustext + '</div>' +
          '<div class="mt-2"><strong>{{# str }} practice_correct_answer, mod_googlemeet {{/ str }}</strong> ' + correcttext + '</div>' +
          '<div class="mt-2">' + response.explanation + '</div>');
      $('.googlemeet-practice-next').removeClass('d-none').text(
        practice.index + 1 >= practice.questions.length
          ? '{{# str }} practice_finish, mod_googlemeet {{/ str }}'
          : '{{# str }} practice_next, mod_googlemeet {{/ str }}'
      ).focus();
    }).fail(function(error) {
      $('.googlemeet-practice-check').prop('disabled', false);
      $('.googlemeet-practice-error').removeClass('d-none').text(error.message || '{{# str }} ai_error_unknown, mod_googlemeet {{/ str }}');
    });
  });

  $('.googlemeet-practice-next').on('click', function() {
    practice.index++;
    if (practice.index >= practice.questions.length) {
      showPracticeComplete();
    } else {
      renderPracticeQuestion();
      $('.googlemeet-practice-stem').attr('tabindex', '-1').focus();
    }
  });

  $('.googlemeet-practice-retry').on('click', function() {
    practice.index = 0;
    renderPracticeQuestion();
  });
  {{/hasquestions}}
  {{/canmanagequestions}}
});
{{/js}}
